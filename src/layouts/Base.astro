---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Maker, creative, and DIYer. Code, wood, art, and sky — all made by hand.',
} = Astro.props;

const fullTitle =
  title === 'sjschroeder.com' ? title : `${title} · sjschroeder.com`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-default.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="sjschroeder.com" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer>
      <div class="inner">
        <span class="dim">made by hand · hosted at home</span>
        <a href="/log">changelog</a>
      </div>
    </footer>
  </body>
</html>

<style>
  footer {
    border-top: 1px solid var(--panel-edge);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  footer .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.1rem 1.4rem 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  footer a {
    color: var(--ink-dim);
  }

  footer a:hover {
    color: var(--amber);
  }
</style>
