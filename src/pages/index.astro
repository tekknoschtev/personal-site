---
import Base from '../layouts/Base.astro';

// Placeholder readout — Phase 3 replaces this with live Uptime Kuma data.
const services = [
  { name: 'dungeon', label: 'Dungeon Crawler' },
  { name: 'trackboard', label: 'TrackBoard' },
  { name: 'astral-surveyor', label: 'Astral Surveyor' },
];

const bootLines = [
  { text: 'sjschroeder.com — personal terminal v0.1', cls: 'dim' },
  { text: 'mounting /projects /workshop /sky /homelab ... ok', cls: 'dim' },
  { text: 'operator identified: maker and DIYer', cls: '' },
];
---

<Base title="sjschroeder.com">
  <div class="crt">
    <section class="boot" aria-label="Intro">
      {bootLines.map((line) => <p class:list={['prompt', line.cls]}>{line.text}</p>)}
      <p class="intro">
        I make things — software, furniture, art, photos of the night sky, and
        the server rack in the basement that hosts all of it. This site is the
        front door: most of the interesting stuff lives on its own subdomain,
        or out in the physical world.
      </p>
    </section>

    <section class="board" aria-label="Systems status">
      <h2>systems</h2>
      <ul>
        {
          services.map((service) => (
            <li>
              <span class="light unknown" aria-hidden="true" />
              <span class="svc">{service.label}</span>
              <span class="tag">awaiting telemetry</span>
            </li>
          ))
        }
      </ul>
      <p class="dim board-note">
        live status board coming online — will read from the homelab's uptime
        monitor
      </p>
    </section>

    <section class="dirs" aria-label="Sections">
      <h2>index</h2>
      <ul>
        <li>
          <a href="/projects">projects/</a>
          <span class="dim">— games and apps, self-hosted. the launcher.</span>
        </li>
        <li>
          <a href="/workshop">workshop/</a>
          <span class="dim">— woodworking and art. sawdust and pigment.</span>
        </li>
        <li>
          <a href="/sky">sky/</a>
          <span class="dim">— astrophotography. early days, honestly.</span>
        </li>
        <li>
          <a href="/homelab">homelab/</a>
          <span class="dim">— the rack that runs this place.</span>
        </li>
        <li>
          <a href="/log">log/</a>
          <span class="dim">— site & project changelog.</span>
        </li>
        <li>
          <a href="/about">about/</a>
          <span class="dim">— who's typing.</span>
        </li>
      </ul>
    </section>
  </div>
</Base>

<style>
  /* starfield behind the hub only */
  :global(body) {
    background-image:
      radial-gradient(1px 1px at 15% 25%, rgba(201, 212, 207, 0.5) 50%, transparent 50%),
      radial-gradient(1px 1px at 45% 70%, rgba(201, 212, 207, 0.35) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 70% 20%, rgba(108, 197, 224, 0.45) 50%, transparent 50%),
      radial-gradient(1px 1px at 85% 55%, rgba(201, 212, 207, 0.4) 50%, transparent 50%),
      radial-gradient(1px 1px at 30% 90%, rgba(255, 180, 84, 0.35) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 60% 45%, rgba(201, 212, 207, 0.3) 50%, transparent 50%),
      radial-gradient(1px 1px at 92% 85%, rgba(201, 212, 207, 0.35) 50%, transparent 50%);
    background-attachment: fixed;
  }

  .crt {
    position: relative;
    font-family: var(--font-mono);
    background: rgba(7, 10, 14, 0.82);
    border: 1px solid var(--border);
    border-radius: 6px;
    box-shadow:
      0 0 30px rgba(107, 241, 120, 0.06),
      inset 0 0 60px rgba(0, 0, 0, 0.5);
    padding: 1.5rem 1.5rem 2rem;
    overflow: hidden;
  }

  /* scanlines — a nod, not a costume */
  .crt::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 3px,
      rgba(0, 0, 0, 0.12) 3px,
      rgba(0, 0, 0, 0.12) 4px
    );
  }

  .boot p {
    margin: 0.25rem 0;
    font-size: 0.85rem;
  }

  .boot .intro {
    font-family: var(--font-body);
    font-size: 1rem;
    margin-top: 1.25rem;
    max-width: 38rem;
  }

  /* staggered boot-in, skipped for reduced motion */
  @media (prefers-reduced-motion: no-preference) {
    .boot p {
      opacity: 0;
      animation: boot-in 0.3s ease-out forwards;
    }
    .boot p:nth-child(1) { animation-delay: 0.1s; }
    .boot p:nth-child(2) { animation-delay: 0.45s; }
    .boot p:nth-child(3) { animation-delay: 0.8s; }
    .boot p:nth-child(4) { animation-delay: 1.15s; }
  }

  @keyframes boot-in {
    from { opacity: 0; transform: translateY(2px); }
    to { opacity: 1; transform: none; }
  }

  h2 {
    font-size: 0.9rem;
    margin: 2rem 0 0.75rem;
  }

  .board ul,
  .dirs ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .board li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0;
    font-size: 0.88rem;
    border-bottom: 1px dashed var(--border);
  }

  .board li:last-child {
    border-bottom: none;
  }

  .board .svc {
    flex: 1;
  }

  .light {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .light.unknown {
    background: var(--ink-dim);
    box-shadow: 0 0 6px rgba(125, 138, 133, 0.6);
  }

  .board-note {
    font-size: 0.75rem;
    margin-top: 0.75rem;
  }

  .dirs li {
    padding: 0.3rem 0;
    font-size: 0.9rem;
  }

  .dirs .dim {
    font-family: var(--font-body);
    font-size: 0.85rem;
    margin-left: 0.35rem;
  }

  .dirs a {
    color: var(--green);
    text-decoration: none;
  }

  .dirs a:hover {
    color: var(--amber);
  }

  @media (max-width: 480px) {
    .crt {
      padding: 1rem 1rem 1.5rem;
    }

    .dirs li {
      padding: 0.45rem 0;
    }

    .dirs .dim {
      display: block;
    }
  }
</style>
