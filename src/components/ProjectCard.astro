---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, tagline, url, repo, tech, monitor } = project.data;
const writeupHref = `/projects/${project.id}`;
const primaryHref = url ?? writeupHref;
---

<article class="module card">
  <div class="rail">
    <h2>
      {
        monitor ? (
          <span
            class="led unknown"
            data-monitor={monitor}
            aria-hidden="true"
          />
        ) : null
      }
      {title}
    </h2>
  </div>
  <p class="tagline">{tagline}</p>
  <p class="tech">
    {tech.map((t: string) => <span class="tag">{t}</span>)}
  </p>
  <p class="links">
    {
      url ? (
        <a class="go" href={url}>
          launch <span aria-hidden="true">→</span>
        </a>
      ) : (
        <a class="go" href={writeupHref}>
          read <span aria-hidden="true">→</span>
        </a>
      )
    }
    {url ? <a class="also" href={writeupHref}>about</a> : null}
    {repo ? <a class="also" href={repo}>source</a> : null}
  </p>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
  }

  .rail h2 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    /* card titles read as names, not shouting labels */
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: 0.95rem;
  }

  .tagline {
    margin: 0;
    font-size: 0.88rem;
    color: var(--ink);
  }

  .tech {
    margin: 0.7rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .links {
    margin: auto 0 0;
    padding-top: 1rem;
    display: flex;
    align-items: baseline;
    gap: 1.2rem;
    font-size: 0.85rem;
  }

  .go {
    font-weight: 700;
    text-decoration: none;
  }

  .go:hover {
    color: var(--ink);
  }

  .also {
    color: var(--ink-dim);
    text-decoration: none;
    font-size: 0.78rem;
  }

  .also:hover {
    color: var(--amber);
  }
</style>
