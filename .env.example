# Status board — Uptime Kuma (values are baked in at build time;
# rebuild after changing them)

# Base URL of the Kuma instance. Two ways to point at it:
#   1. Absolute URL (Kuma on its own subdomain, must allow CORS):
#      PUBLIC_KUMA_URL=https://status.sjschroeder.com
#   2. Relative path (nginx on the site box proxies /kuma -> the Kuma
#      container; same origin, no CORS involved):
#      PUBLIC_KUMA_URL=/kuma
# Leave unset while Kuma isn't stood up — the board degrades gracefully.
PUBLIC_KUMA_URL=

# Slug of the Kuma status page to read (Kuma sidebar -> Status Pages).
# The page must include every monitor the site should show.
PUBLIC_KUMA_PAGE=public
